# Required: Your wallet private key (256-bit hex, 64 chars)
# Generate with: openssl rand -hex 32
POLYMARKET_PRIVATE_KEY=

# Required: Proxy wallet address (0x-prefixed)
# Get via: polymarket derive-api-key
POLYMARKET_PROXY=

# Optional: CLOB API credentials (for authenticated endpoints)
# Get via: polymarket derive-api-key
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# Optional: Workspace directory (defaults to cwd)
# POLYMARKET_WORKSPACE=/path/to/workspace

# Optional: Position manager overrides
# PM_TAKE_PROFIT=0.05
# PM_STOP_LOSS=-0.20
# PM_EMERGENCY_FLOOR=0.01
# PM_FAST_POLL=30
# PM_SLOW_POLL=300
